# ─────────────────────────────────────────────────────
# IncentivaBR — Variáveis de Ambiente (Desenvolvimento)
# ─────────────────────────────────────────────────────
# ATENÇÃO: nunca commitar este arquivo com dados reais!
# Copie para .env e ajuste os valores.

# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados PostgreSQL
# Se usar docker-compose: host=localhost, user/pass=incentivabr
# Se usar PostgreSQL local: ajuste conforme sua instalação
DB_HOST=localhost
DB_PORT=5432
DB_USER=incentivabr
DB_PASSWORD=incentivabr123
DB_NAME=incentivabr

# JWT — TROCAR em produção por string longa e aleatória
JWT_SECRET=dev_jwt_secret_mudar_em_producao_usar_openssl_rand

# ─── Email (opcional para desenvolvimento) ────────────
# Deixe em branco: o sistema usa Ethereal (emails de teste)
# Para ver emails de teste: acesse o link impresso no console
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Para produção (Railway, Render, etc.) ────────────
# Descomente e use a URL completa em vez das variáveis acima:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
