# ─────────────────────────────────────────────────────
# DestineAI / IncentivaBR — Variáveis de Ambiente
# ─────────────────────────────────────────────────────
# ATENÇÃO: nunca commitar .env com dados reais!

# Servidor
PORT=3000
NODE_ENV=production

# URL pública da aplicação (usada em links de email)
APP_URL=https://www.destineai.com.br

# Banco de Dados
# Em produção (Railway): use DATABASE_URL gerado automaticamente pelo plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Em dev local:
#DB_HOST=localhost
#DB_PORT=5432
#DB_USER=incentivabr
#DB_PASSWORD=incentivabr123
#DB_NAME=incentivabr

# JWT
JWT_SECRET=troque_por_string_longa_e_aleatoria
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ───────────────────────────────────────────────────
# Email (SMTP)
# ───────────────────────────────────────────────────
# Dev: deixe em branco — usa Ethereal (emails fake, link no console)
# Prod: preencha com seu provedor

# Opção A — Gmail (requer Senha de App, não a senha normal)
# Gere em: myaccount.google.com > Segurança > Senhas de app
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=seu@gmail.com
#SMTP_PASS=xxxx_xxxx_xxxx_xxxx
#SMTP_FROM="DestineAI" <seu@gmail.com>

# Opção B — Resend (recomendado para produção, plano free até 3k/mês)
# Crie conta em resend.com, adicione domínio destineai.com.br e gere API key
#SMTP_HOST=smtp.resend.com
#SMTP_PORT=465
#SMTP_SECURE=true
#SMTP_USER=resend
#SMTP_PASS=re_sua_api_key_aqui
#SMTP_FROM="DestineAI" <noreply@destineai.com.br>

# Opção C — SendGrid
#SMTP_HOST=smtp.sendgrid.net
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=apikey
#SMTP_PASS=SG.sua_api_key
#SMTP_FROM="DestineAI" <noreply@destineai.com.br>

# ───────────────────────────────────────────────────
# White-label / Marca
# ───────────────────────────────────────────────────
BRAND_NAME=DestineAI
BRAND_DOMAIN=www.destineai.com.br
BRAND_LOGO_URL=/assets/logo-destineai.png
BRAND_COLOR_PRIMARY=#273F77
BRAND_COLOR_ACCENT=#EE985C
