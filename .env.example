# ================================
# IncentivaBR Rouanet — .env.example
# Copie para .env e preencha os valores
# ================================

# Servidor
PORT=3000
NODE_ENV=development

# White-label — Marca do cliente
BRAND_NAME=Destinai
BRAND_DOMAIN=destinai.com.br
BRAND_COLOR_PRIMARY=#5B21B6
BRAND_COLOR_SECONDARY=#7C3AED
BRAND_LOGO_URL=/assets/logo.png
BRAND_CNPJ=

# Banco de dados (PostgreSQL)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/rouanet_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rouanet_db
DB_USER=usuario
DB_PASSWORD=senha

# JWT
JWT_SECRET=sua_chave_secreta_aqui
JWT_EXPIRES_IN=7d

# SALIC API (Ministério da Cultura)
SALIC_API_BASE_URL=http://api.salic.cultura.gov.br/v1
SALIC_API_KEY=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@destinai.com.br

# WhatsApp (opcional)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Upload
UPLOAD_MAX_SIZE_MB=10
