{
  "name": "destineai-tests",
  "version": "1.0.0",
  "description": "Testes automatizados — API + E2E (Playwright)",
  "type": "module",
  "scripts": {
    "test:api":  "node --test --test-reporter=spec api/*.test.js",
    "test:e2e":  "npx playwright test --config e2e/playwright.config.js",
    "test":      "npm run test:api && npm run test:e2e",
    "report":    "npx playwright show-report"
  },
  "dependencies": {
    "@playwright/test": "^1.44.0"
  }
}
